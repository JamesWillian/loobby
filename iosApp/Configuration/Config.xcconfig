TEAM_ID=

PRODUCT_NAME=Loobby
PRODUCT_BUNDLE_IDENTIFIER=app.loobby.Loobby$(TEAM_ID)

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// SQLDelight (co.touchlab:sqliter) usa cinterop contra o libsqlite3 do sistema.
// Sem este flag, o linker do Xcode falha com "Undefined symbols: _sqlite3_*".
OTHER_LDFLAGS = $(inherited) -lsqlite3